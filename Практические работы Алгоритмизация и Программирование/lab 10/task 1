'''
Напишите программу, эмулирующую электронный замок. Правильный пин-код 4590. 
'''
true_pin = 4590

while True:
    s = int(input("Введи код праток, без него нельзя "))
    if s < 1000 or s > 9999:
        continue
    if s == true_pin:
        print("Ну ладно праток в этот раз угадал")
        break
    else:
        print("Пратик вообще не верно ну емае((( ")


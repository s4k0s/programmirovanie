'''
Задача 3. «Рекордсмен» (Поиск максимума) 
Напишите программу, которая находит самое большое число в введенной последовательности.
'''
max_num = None
while True:
    n = int(input("Введи число ну емае((, если введешь 0 то программка остановится "))
    if n == 0:
        break
    if max_num is None or n > max_num:
        max_num = n

print("Максимальное число из всех введенных это", max_num)


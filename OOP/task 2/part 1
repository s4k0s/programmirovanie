class Monster:
    def __init__ (self, name='Незвестная монстра', hp=100,dmg=10):
        self.name = name
        self.hp = hp
        self.dmg = dmg


    def show_info(self):
        print(f"---------- Статус ----------")
        print(f"Имя: {self.name}")
        print(f"Здоровье монстра = {self.hp}")
        print(f"Дамаг монстра = {self.dmg}")
        print("----------------------------")


m1 = Monster("Горгулья",120,18)
m1.show_info()
